<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <Description>Concertable B2B Concert contracts: the cross-service concert contract surface — integration events (ConcertChangedEvent, ConcertPostedEvent, ConcertFinishedEvent, ConcertSettledEvent, …) and view DTOs consumed by services downstream of B2B (Search, Customer).</Description>
  </PropertyGroup>

  <!-- Keep as PackageReference, never a ProjectReference: a cross-folder escape from api/Concertable.B2B/ breaks the standalone carve (see Directory.Build.props). -->
  <ItemGroup>
    <PackageReference Include="Concertable.Contracts" />
    <PackageReference Include="Concertable.Kernel" />
    <PackageReference Include="Concertable.Messaging.Contracts" />
  </ItemGroup>

</Project>
