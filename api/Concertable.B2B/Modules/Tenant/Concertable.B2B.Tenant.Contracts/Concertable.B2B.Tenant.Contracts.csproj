<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <Description>Concertable B2B Tenant contracts: the cross-service tenant/permission contract surface and integration events (incl. TenantCreatedEvent) consumed by services downstream of B2B.</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- AuthorizeAttribute for [HasPermission], the cross-module authz surface. -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- Keep as PackageReference, never a ProjectReference: a cross-folder escape from api/Concertable.B2B/ breaks the standalone carve (see Directory.Build.props). -->
  <ItemGroup>
    <PackageReference Include="Concertable.Contracts" />
    <PackageReference Include="Concertable.Kernel" />
    <PackageReference Include="Concertable.Messaging.Contracts" />
  </ItemGroup>

</Project>
