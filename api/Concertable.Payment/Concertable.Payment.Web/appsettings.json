{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5174",
      "https://localhost:5175",
      "https://localhost:5176",
      "https://localhost:5177"
    ]
  },
  "ExternalServices": {
    // Set to false locally when you don't want to call the real Stripe API (e.g. pure business-logic testing).
    // E2E tests always override this to true via appsettings.E2E.json — the E2E suite always hits real Stripe.
    "UseRealStripe": false
  }
}
