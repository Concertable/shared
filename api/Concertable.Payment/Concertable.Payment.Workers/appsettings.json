{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ExternalServices": {
    // Set to false locally when you don't want to call the real Stripe API (e.g. pure business-logic testing).
    // E2E tests always override this to true via appsettings.E2E.json — the E2E suite always hits real Stripe.
    "UseRealStripe": false
  }
}
